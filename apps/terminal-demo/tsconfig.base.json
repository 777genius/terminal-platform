{
  "compilerOptions": {
    "target": "ES2023",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@features/terminal-workspace-kernel/contracts": ["src/features/terminal-workspace-kernel/contracts/index.ts"],
      "@features/terminal-runtime-host/contracts": ["src/features/terminal-runtime-host/contracts/index.ts"],
      "@features/terminal-runtime-host/main": ["src/features/terminal-runtime-host/main/index.ts"],
      "@features/terminal-runtime-host/preload": ["src/features/terminal-runtime-host/preload/index.ts"],
      "@features/terminal-runtime-host/renderer": ["src/features/terminal-runtime-host/renderer/index.ts"],
      "@features/terminal-workspace-catalog/renderer": ["src/features/terminal-workspace-catalog/renderer/index.ts"],
      "@features/terminal-saved-sessions/renderer": ["src/features/terminal-saved-sessions/renderer/index.ts"],
      "@features/terminal-active-session/renderer": ["src/features/terminal-active-session/renderer/index.ts"],
      "@features/terminal-input-composer/renderer": ["src/features/terminal-input-composer/renderer/index.ts"],
      "@features/*": ["src/features/*"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  }
}
