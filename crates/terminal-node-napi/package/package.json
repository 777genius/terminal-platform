{
  "name": "terminal-platform-node",
  "version": "0.1.0",
  "description": "Thin Node/Electron SDK for Terminal Platform",
  "license": "MIT",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.cjs",
      "import": "./index.mjs"
    }
  },
  "scripts": {
    "stage": "node ./scripts/stage-package.mjs",
    "build:local": "node ./scripts/build-local-package.mjs",
    "verify:layout": "node ./scripts/verify-package.mjs",
    "pack:local": "node ./scripts/pack-local-package.mjs"
  },
  "files": [
    "README.md",
    "index.cjs",
    "index.mjs",
    "index.d.ts",
    "bindings",
    "native"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
